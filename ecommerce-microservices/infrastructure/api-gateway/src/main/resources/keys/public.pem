# QUICK SETUP (run these commands from the project root):
#
#   Option A — OpenSSL:
#     cd microservices\customer-service\src\main\resources\keys
#     openssl genrsa -out private_raw.pem 2048
#     openssl pkcs8 -topk8 -inform PEM -outform PEM -nocrypt -in private_raw.pem -out private.pem
#     openssl rsa -in private.pem -pubout -out public.pem
#     copy public.pem ..\..\..\..\..\..\..\infrastructure\api-gateway\src\main\resources\keys\public.pem
#
#   Option B — Java utility (no OpenSSL):
#     java scripts\GenerateRSAKeys.java
#
# After generation, this file should look like:
#   -----BEGIN PUBLIC KEY-----
#   MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
#   -----END PUBLIC KEY-----
